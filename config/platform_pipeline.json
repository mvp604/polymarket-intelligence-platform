      "required": true,
      "timeout_seconds": 900
    },
    {
      "order": 30,
      "name": "Threshold Optimizer",
      "runner": "run_threshold_optimizer.ps1",
      "latest_report": "reports/threshold_optimizer/latest.html",
      "enabled": true,
      "required": false,
      "timeout_seconds": 900
    }
  ]
}
